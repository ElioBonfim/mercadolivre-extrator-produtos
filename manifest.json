{
  "manifest_version": 3,
  "name": "Mercado Livre - Extrator de Produtos",
  "version": "1.0",
  "description": "Extrai e lista todos os produtos exibidos na página do Mercado Livre",
  "permissions": ["activeTab", "scripting", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "host_permissions": ["https://mercadolivre.com.br/*", "https://*.mercadolivre.com.br/*"],
  "content_scripts": [
    {
      "matches": ["https://mercadolivre.com.br/*", "https://*.mercadolivre.com.br/*"],
      "js": ["content.js"]
    }
  ]
}
